# =============================================================================
# nginx server block for the intranet (Laravel 11 + Filament 3).
#
# Copy to /etc/nginx/sites-available/intranet.overseas.hr, adjust the cert paths
# and the PHP-FPM socket version, then:
#   sudo ln -s /etc/nginx/sites-available/intranet.overseas.hr /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# See SETUP.md §7 for the full deployment steps.
# =============================================================================

# HTTP -> HTTPS (matches APP_ENV=production, which forces HTTPS app-wide).
server {
    listen 80;
    listen [::]:80;
    server_name intranet.overseas.hr;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name intranet.overseas.hr;

    root /var/www/sites/intranet.overseas.hr/public;
    index index.php;
    charset utf-8;

    # Wildcard *.overseas.hr certificate.
    ssl_certificate     /etc/ssl/overseas/wildcard.overseas.hr.crt;
    ssl_certificate_key /etc/ssl/overseas/wildcard.overseas.hr.key;

    # MUST be >= PHP post_max_size (24M) or large uploads (doc attachments, APKs)
    # are rejected by nginx before ever reaching PHP. nginx default is only 1M.
    client_max_body_size 24M;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        # Match the installed PHP-FPM version.
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        include fastcgi_params;
    }

    # Long-cache built/static assets.
    location ~* \.(?:css|js|png|jpe?g|gif|svg|webp|ico|woff2?|ttf)$ {
        expires 7d;
        access_log off;
        try_files $uri =404;
    }

    # Block dotfiles (.env, .git, …) but allow ACME / .well-known.
    location ~ /\.(?!well-known).* {
        deny all;
    }

    access_log /var/log/nginx/intranet.overseas.hr.access.log;
    error_log  /var/log/nginx/intranet.overseas.hr.error.log;
}
